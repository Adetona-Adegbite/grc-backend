generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  fullName         String?
  avatarUrl        String?
  password         String?
  googleId         String?   @unique
  createdAt        DateTime  @default(now())
  resetToken       String?
  resetTokenExpiry DateTime?

  ownedCompanies    Company[]          @relation("CompanyOwner")
  userCompanies     UserCompany[]
  ownedControls     Control[]          @relation("ControlOwner")
  sentInvites       Invite[]           @relation("InvitedBy")
  testPlanOverrides TestPlanOverride[] @relation("TestPlanTester")
  testerControls    Control[]          @relation("ControlTester")
  testResults       TestResult[]       @relation("TestResultTester")
  ownedIssues       Issue[]            @relation("IssueOwner")
  ownedActions      Action[]           @relation("ActionOwner")
  auditLogs         AuditLog[]

  @@map("users")
}

model Company {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  ownerId            String
  financialYearStart Int      @default(1)
  createdAt          DateTime @default(now())

  owner             User               @relation("CompanyOwner", fields: [ownerId], references: [id])
  userCompanies     UserCompany[]
  countries         Country[]
  controls          Control[]
  invites           Invite[]
  testPlanOverrides TestPlanOverride[]
  TestResult        TestResult[]
  issues            Issue[]
  actions           Action[]
  auditLogs         AuditLog[]

  @@map("companies")
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  role      Role     @default(viewer)
  invitedBy String?
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("user_company")
}

enum Role {
  admin
  control_owner
  tester
  viewer
}

model Country {
  id        String   @id @default(uuid())
  companyId String
  name      String
  code      String
  createdAt DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id])
  controls    Control[]
  testResults TestResult[]
  issues      Issue[]

  @@unique([companyId, code])
  @@map("countries")
}

model Control {
  id          String        @id @default(uuid())
  companyId   String
  countryId   String
  controlId   String
  description String
  name        String
  domain      String
  risk        String
  frequency   Frequency
  ownerId     String?
  testerId    String?
  nature      Nature
  type        ControlType
  testDueDay  Int           @default(15)
  status      ControlStatus @default(active)
  createdAt   DateTime      @default(now())

  company           Company            @relation(fields: [companyId], references: [id])
  country           Country            @relation(fields: [countryId], references: [id])
  owner             User?              @relation("ControlOwner", fields: [ownerId], references: [id])
  tester            User?              @relation("ControlTester", fields: [testerId], references: [id])
  testPlanOverrides TestPlanOverride[]
  testResults       TestResult[]
  issues            Issue[]

  @@unique([companyId, controlId, countryId])
  @@map("controls")
}

enum Nature {
  manual
  automated
}

enum ControlType {
  preventive
  detective
  corrective
}

enum Frequency {
  monthly
  quarterly
  semi_annually
  annual
  as_needed
}

enum ControlStatus {
  active
  inactive
}

model TestResult {
  id            String           @id @default(uuid())
  testId        String
  companyId     String
  countryId     String
  controlId     String
  testerId      String
  period        String
  testName      String
  population    Int
  sampleSize    Int
  exceptions    Int
  result        TestResultStatus
  testProcedure String?
  evidenceUrl   String?
  comments      String?
  testedAt      DateTime         @default(now())
  createdAt     DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id])
  country Country @relation(fields: [countryId], references: [id])
  control Control @relation(fields: [controlId], references: [id])
  tester  User    @relation("TestResultTester", fields: [testerId], references: [id])
  issues  Issue[]

  @@unique([companyId, controlId, period])
  @@unique([companyId, testId])
  @@map("test_results")
}

enum TestResultStatus {
  pass
  exception
  fail
}

model Invite {
  id        String       @id @default(uuid())
  companyId String
  email     String
  role      Role
  token     String       @unique @default(uuid())
  status    InviteStatus @default(pending)
  invitedBy String
  createdAt DateTime     @default(now())
  expiresAt DateTime

  company Company @relation(fields: [companyId], references: [id])
  inviter User    @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@map("invites")
}

enum InviteStatus {
  pending
  accepted
  expired
  declined
}

model TestPlanOverride {
  id        String   @id @default(uuid())
  companyId String
  controlId String
  testerId  String
  period    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  control Control @relation(fields: [controlId], references: [id])
  tester  User    @relation("TestPlanTester", fields: [testerId], references: [id])

  @@unique([companyId, controlId, period])
  @@map("test_plan_overrides")
}

model Issue {
  id           String      @id @default(uuid())
  issueId      String
  companyId    String
  countryId    String
  controlId    String
  testResultId String?
  description  String
  severity     Severity    @default(medium)
  ownerId      String?
  dueDate      DateTime?
  status       IssueStatus @default(open)
  evidenceUrl  String?
  createdAt    DateTime    @default(now())
  testerClosed Boolean     @default(false)

  company    Company     @relation(fields: [companyId], references: [id])
  country    Country     @relation(fields: [countryId], references: [id])
  control    Control     @relation(fields: [controlId], references: [id])
  testResult TestResult? @relation(fields: [testResultId], references: [id])
  owner      User?       @relation("IssueOwner", fields: [ownerId], references: [id])
  actions    Action[]

  @@unique([companyId, issueId])
  @@map("issues")
}

model Action {
  id          String       @id @default(uuid())
  actionId    String
  issueId     String
  companyId   String
  description String
  ownerId     String?
  dueDate     DateTime?
  progress    Int          @default(0)
  status      ActionStatus @default(in_progress)
  lastUpdate  DateTime     @default(now())
  createdAt   DateTime     @default(now())

  issue   Issue   @relation(fields: [issueId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  owner   User?   @relation("ActionOwner", fields: [ownerId], references: [id])

  @@unique([companyId, actionId])
  @@map("actions")
}

enum Severity {
  low
  medium
  high
}

enum IssueStatus {
  open
  in_progress
  closed
}

enum ActionStatus {
  in_progress
  completed
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  action     String
  entityType String
  entityId   String
  detail     String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
